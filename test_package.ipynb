    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# LLM Feature Gen — Test Notebook\\n\",\n",
    "    \"\\n\",\n",
    "    \"Tests **discover** and **generate** for all modalities using both:\\n\",\n",
    "    \"- 🟢 **Local (Ollama)** via `LocalProvider`\\n\",\n",
    "    \"- 🔵 **OpenAI / Azure** via `OpenAIProvider`\\n\",\n",
    "    \"\\n\",\n",
    "    \"---\\n\",\n",
    "    \"### Setup\\n\",\n",
    "    \"Make sure your `.env` file contains the relevant keys:\\n\",\n",
    "    \"```\\n\",\n",
    "    \"# OpenAI / Azure\\n\",\n",
    "    \"OPENAI_API_KEY=...\\n\",\n",
    "    \"OPENAI_MODEL=gpt-4o\\n\",\n",
    "    \"OPENAI_AUDIO_MODEL=whisper-1\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Local (Ollama)\\n\",\n",
    "    \"LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1\\n\",\n",
    "    \"LOCAL_OPENAI_API_KEY=ollama\\n\",\n",
    "    \"LOCAL_MODEL_TEXT=llama3\\n\",\n",
    "    \"LOCAL_MODEL_VISION=llava\\n\",\n",
    "    \"```\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
