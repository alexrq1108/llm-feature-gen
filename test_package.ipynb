    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# ── OpenAI provider ───────────────────────────────────────────────────────────\\n\",\n",
    "    \"try:\\n\",\n",
    "    \"    openai_provider = OpenAIProvider()\\n\",\n",
    "    \"    print(f\\\"🔵 OpenAIProvider ready  |  model={openai_provider.default_model}  |  azure={openai_provider.is_azure}\\\")\\n\",\n",
    "    \"except EnvironmentError as e:\\n\",\n",
